# Supabase Project URL — found in your Supabase dashboard under Settings > API
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon (public) API Key — also found under Settings > API
# This key is safe for client-side usage due to Row Level Security
VITE_SUPABASE_ANON_KEY=your-anon-key-here
